NODE_ENV=development
PORT=3000

# 런타임 연결.
# 로컬: 아래 로컬 postgres 주소 그대로 사용(TLS 불필요).
# Supabase: 트랜잭션 풀러(6543) 주소 + 끝에 ?sslmode=require 를 붙입니다.
#   postgresql://postgres.<ref>:<pw>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/team_mino

# 마이그레이션/스키마 준비용 — 세션 모드 연결(Supabase 풀러 5432).
# 미설정 시 마이그레이션 명령은 에러로 막힙니다(트랜잭션 풀러에서 DDL이 깨질 수 있어 폴백 안 함).
#   postgresql://postgres.<ref>:<pw>@aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/team_mino

# 접근할 스키마(환경 분리). 미설정 시 develop. 운영에서만 production 으로 주입.
# DATABASE_SCHEMA=develop

# 인스턴스당 최대 커넥션 수(기본 5).
DB_POOL_SIZE=5

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=team_mino
